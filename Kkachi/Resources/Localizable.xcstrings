    "menu.atRisk.blocked.help" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi couldn’t confirm this tab was safe to close. Close or protect it yourself."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このタブを安全に閉じられるか確認できませんでした。手動で閉じるか、保護してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 탭을 안전하게 닫아도 되는지 확인하지 못했어요. 직접 닫거나 보호해 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 无法确认此标签页可安全关闭。请手动关闭，或将其保护。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 無法確認此分頁可安全關閉。請手動關閉，或將其保護。"
          }
        }
      }
    },
