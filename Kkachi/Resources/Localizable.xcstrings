    "settings.privacy.clearHistory.confirm.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tabs Kkachi tucked away will be permanently forgotten. This can’t be undone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi が保管したタブは完全に削除され、元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi가 보관한 탭이 영구적으로 삭제되며 되돌릴 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 暂存的标签页将被永久删除，且无法恢复。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 暫存的分頁將被永久刪除，且無法復原。"
          }
        }
      }
    },
    "settings.privacy.clearHistory.confirm.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear restore history?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "復元履歴を消去しますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "복원 기록을 지울까요?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除恢复历史？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除復原記錄？"
          }
        }
      }
    },
    "settings.privacy.message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi stores restore history locally with each tab's URL and title, checks media playback only for close safety, and does not collect cookies or browser storage."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi は各タブの URL とタイトルを含む復元履歴をローカルに保存し、閉じる安全確認のためだけにメディア再生状態を確認し、Cookie やブラウザストレージは収集しません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi는 각 탭의 URL과 제목이 포함된 복원 기록을 로컬에 저장하고, 닫아도 안전한지 확인할 때만 미디어 재생 상태를 확인하며, 쿠키나 브라우저 저장소는 수집하지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 会在本地保存包含标签页 URL 和标题的恢复历史，仅为安全关闭而检查媒体播放状态，并且不会收集 Cookie 或浏览器存储。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 會在本機保存包含分頁 URL 和標題的還原記錄，僅為安全關閉而檢查媒體播放狀態，且不會收集 Cookie 或瀏覽器儲存空間。"
          }
        }
      }
    },
    "settings.privacy.section" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プライバシー"
          }
        },
