{
  "sourceLanguage" : "en",
  "strings" : {
    "CFBundleName" : {
      "comment" : "Bundle name",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Kkachi"
          }
        }
      }
    },
    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi reads browser tab addresses, titles, and audio/video playback state to find idle tabs safely. It does not collect page content, and nothing about your tabs leaves your Mac."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi はタブのアドレス、タイトル、音声や動画の再生状態を読み取り、アイドル状態のタブを安全に見つけます。ページ内容は収集せず、タブに関する情報が Mac の外に出ることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi는 탭의 주소, 제목, 오디오/비디오 재생 상태를 읽어 유휴 탭을 안전하게 찾습니다. 페이지 내용은 수집하지 않으며, 탭에 관한 정보는 Mac을 벗어나지 않습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 会读取标签页地址、标题以及音频/视频播放状态，以安全识别闲置标签页。它不会收集页面内容，且有关标签页的信息不会离开你的 Mac。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kkachi 會讀取分頁位址、標題以及音訊/影片播放狀態，以安全識別閒置分頁。它不會收集頁面內容，且有關分頁的資訊不會離開你的 Mac。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}
